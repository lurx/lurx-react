{
	"name": "story-wise",
	"$schema": "../../node_modules/nx/schemas/project-schema.json",
	"sourceRoot": "apps/story-wise",
	"projectType": "application",
	"tags": [],
	"targets": {
		"build": {
			"executor": "@nx/next:build",
			"options": {
				"outputPath": "dist/apps/story-wise"
			},
			"dependsOn": ["test"]
		},
		"serve": {
			"executor": "@nx/next:server",
			"options": {
				"buildTarget": "story-wise:build",
				"dev": true
			}
		},
		"test": {
			"executor": "@nx/jest:jest",
			"outputs": ["{workspaceRoot}/coverage/apps/story-wise"],
			"options": {
				"jestConfig": "apps/story-wise/jest.config.ts"
			}
		}
	}
}
