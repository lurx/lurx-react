{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"outDir": "../../dist/out-tsc",
		"module": "commonjs",
		"moduleResolution": "node",
		"jsx": "react-jsx",
		"types": ["jest", "node", "@testing-library/jest-dom"]
	},
	"include": [
		"jest.config.ts",
		"jest.setup.ts",
		"__mocks__/**/*",
		"src/**/*.test.ts",
		"src/**/*.spec.ts",
		"src/**/*.test.tsx",
		"src/**/*.spec.tsx"
	],
	"exclude": []
}
