{
	"name": "rotem-is-a-dev",
	"$schema": "../../node_modules/nx/schemas/project-schema.json",
	"sourceRoot": "apps/rotem-is-a-dev/src",
	"projectType": "application",
	"tags": ["ui"],
	"targets": {
		"build": {
			"executor": "@nx/next:build",
			"options": {
				"outputPath": "apps/rotem-is-a-dev"
			}
		},
		"serve": {
			"executor": "@nx/next:server",
			"options": {
				"buildTarget": "rotem-is-a-dev:build",
				"dev": true
			}
		},
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": [
          "apps/rotem-is-a-dev/src/**/*.{ts,tsx,js,jsx}",
          "apps/rotem-is-a-dev/*.{ts,tsx,js,jsx,cjs,mjs}"
        ]
      }
    }
	}
}
