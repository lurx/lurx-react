{
  "name": "vanguardis-mcp-server",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/vanguardis-mcp-server/src",
  "projectType": "library",
  "tags": ["mcp", "server", "design-system"],
  "implicitDependencies": ["vanguardis"],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/vanguardis-mcp-server",
        "main": "libs/vanguardis-mcp-server/src/index.ts",
        "tsConfig": "libs/vanguardis-mcp-server/tsconfig.lib.json"
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{options.outputPath}"],
      "options": {
        "jestConfig": "libs/vanguardis-mcp-server/jest.config.ts"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["libs/vanguardis-mcp-server/src/**/*.{ts,tsx,js,jsx}"]
      }
    },
    "serve": {
      "executor": "@nx/js:node",
      "options": {
        "buildTarget": "vanguardis-mcp-server:build"
      }
    }
  }
}
