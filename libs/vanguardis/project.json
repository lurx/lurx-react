{
	"name": "vanguardis",
	"$schema": "../../node_modules/nx/schemas/project-schema.json",
	"sourceRoot": "libs/vanguardis/src",
	"projectType": "library",
	"tags": ["design-system", "ui", "components"],
	"targets": {
		"build": {
			"executor": "@nx/vite:build",
			"outputs": ["{options.outputPath}"],
			"options": {
				"outputPath": "dist/libs/vanguardis"
			}
		},
		"test": {
			"executor": "@nx/jest:jest",
			"outputs": ["{options.outputPath}"],
			"options": {
				"jestConfig": "libs/vanguardis/jest.config.ts"
			}
		},
		"lint": {
			"executor": "@nx/eslint:lint",
			"outputs": ["{options.outputFile}"],
			"options": {
				"lintFilePatterns": ["libs/vanguardis/**/*.{ts,tsx,js,jsx}"]
			}
		}
	}
}
